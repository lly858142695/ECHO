{
  "name": "echo-next",
  "version": "0.0.0",
  "description": "ECHO Next Phase 0 desktop music app shell.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:full": "npm run rebuild:native && npm run build:audio-host && electron-vite dev",
    "build:audio-host": "node scripts/build-audio-host.mjs",
    "smoke:audio-host": "node scripts/smoke-audio-host.mjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "sync:audio-host": "node scripts/sync-audio-host.mjs",
    "build": "npm run typecheck && electron-vite build",
    "check:encoding": "node scripts/check-encoding.mjs",
    "lint": "npm run check:encoding && eslint .",
    "pretest": "npm run rebuild:native:node",
    "test": "vitest run",
    "posttest": "npm run rebuild:native",
    "typecheck": "tsc --noEmit",
    "prebenchmark:library": "npm run rebuild:native:node",
    "benchmark:library": "node scripts/benchmark-library.mjs",
    "postbenchmark:library": "npm run rebuild:native",
    "repair:electron": "node scripts/install-electron.cjs"
  },
  "dependencies": {
    "@fontsource/outfit": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.9.0",
    "electron-vite": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.468.0",
    "music-metadata": "^11.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "taglib-wasm": "^1.1.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "electron": "^37.10.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  }
}
